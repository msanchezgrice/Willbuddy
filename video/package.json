{
  "name": "willbuddy-video-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "compositions": "remotion compositions src/index.ts",
    "render:suite": "remotion render src/index.ts SuiteOverview output/willbuddy-tools-suite.mp4 --codec h264 --crf 18",
    "render:shorts": "node render-shorts.mjs",
    "render:thumbnails": "node render-thumbnails.mjs",
    "render:all": "npm run render:suite && npm run render:shorts && npm run render:thumbnails",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.489",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.489"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
