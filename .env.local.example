# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini (server-side only, used for token minting)
GEMINI_API_KEY=your-gemini-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email
RESEND_API_KEY=re_your-key
RESEND_FROM="WillBuddy <hello@mywillbuddy.com>"
SUPPORT_EMAIL=support@mywillbuddy.com
# Optional: where user replies to drip/transactional emails are routed.
# Defaults to SUPPORT_EMAIL when unset.
RESEND_REPLY_TO=support@mywillbuddy.com
