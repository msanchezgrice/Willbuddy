# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini (server-side only, used for token minting)
GEMINI_API_KEY=your-gemini-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Clerk
# Local/dev can use Clerk test keys. Vercel Production must use Clerk live keys
# from the production Clerk instance: pk_live_* and sk_live_*.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Email
# Production must use a verified Resend sender on mywillbuddy.com.
RESEND_API_KEY=re_your-resend-key
RESEND_FROM="WillBuddy <support@mywillbuddy.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
